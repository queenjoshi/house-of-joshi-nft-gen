# WalletConnect Project ID for RainbowKit
# Get your project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Reown Project ID (deprecated - kept for reference)
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Pinata IPFS Configuration
# Get your API keys from https://app.pinata.cloud/
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key
PINATA_JWT=your_pinata_jwt_token

# BaseScan API Key for contract verification
# Get your API key from https://basescan.org/myapikey
NEXT_PUBLIC_BASESCAN_API_KEY=your_basescan_api_key

# AI Generation APIs
# Stability AI API Key for image generation
# Get your API key from https://platform.stability.ai/
STABILITY_API_KEY=your_stability_ai_api_key

# Background Removal API Key (remove.bg)
# Get your API key from https://www.remove.bg/api
REMOVAL_API_KEY=your_remove_bg_api_key
