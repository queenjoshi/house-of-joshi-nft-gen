{
  "name": "House of Joshi Launchpad",
  "short_name": "House of Joshi",
  "description": "Create, launch, and mint generative NFT collections on Base",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#1a0a2e",
  "theme_color": "#6E44FF",
  "orientation": "portrait",
  "scope": "/",
  "icons": [
    {
      "src": "/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["finance", "business"],
  "shortcuts": [
    {
      "name": "Launchpad",
      "short_name": "Launchpad",
      "description": "Create and launch NFT collections",
      "url": "/launchpad",
      "icons": [{ "src": "/joshi-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Collections",
      "short_name": "Collections",
      "description": "Browse NFT collections",
      "url": "/collections",
      "icons": [{ "src": "/joshi-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Your NFT dashboard",
      "url": "/dashboard",
      "icons": [{ "src": "/joshi-logo.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [
    {
      "platform": "web",
      "url": "https://nftlaunchpad.thehouseofjoshi.com"
    },
    {
      "platform": "playstore",
      "id": "com.houseofjoshi.app",
      "url": "https://play.google.com/store/apps/details?id=com.houseofjoshi.app"
    },
    {
      "platform": "itunes",
      "id": "com.houseofjoshi.app",
      "url": "https://apps.apple.com/app/com.houseofjoshi.app"
    }
  ],
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/og-image.png",
      "sizes": "1200x630",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+joshi",
      "url": "/?wallet=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "images",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "handle_links": "preferred",
  "capture_links": "existing-client-event"
}
